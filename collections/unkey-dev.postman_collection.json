            "url": { "raw": "{{baseUrl}}/v2/identities.getIdentity", "host": ["{{baseUrl}}"], "path": ["v2", "identities.getIdentity"] },
            "description": "Retrieves an identity by its identityId or externalId."
          }
        },
        {
          "name": "List identities",
          "request": {
