            "body": { "mode": "raw", "raw": "{\n  \"externalId\": \"org_123\"\n}" },
            "url": { "raw": "{{baseUrl}}/v2/identities.createIdentity", "host": ["{{baseUrl}}"], "path": ["v2", "identities.createIdentity"] },
            "description": "Creates an identity representing a user, tenant, or organization, keyed by an externalId."
          }
        },
        {
          "name": "Get an identity",
          "request": {
